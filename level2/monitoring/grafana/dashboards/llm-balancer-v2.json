{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Latency (p50/p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.5, rate(llm_llm_request_latency_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(llm_llm_request_latency_seconds_bucket[5m]))", "legendFormat": "p95" }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Requests by Provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "rate(llm_llm_requests_total[5m])", "legendFormat": "{{provider}}" }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "TTFT (Time to First Token)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.5, rate(llm_llm_ttft_seconds_bucket[5m]))", "legendFormat": "TTFT p50" },
        { "expr": "histogram_quantile(0.95, rate(llm_llm_ttft_seconds_bucket[5m]))", "legendFormat": "TTFT p95" }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "TPOT (Time per Output Token)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "rate(llm_llm_tpot_seconds_sum[5m]) / rate(llm_llm_tpot_seconds_count[5m])", "legendFormat": "TPOT avg" }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Token Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "rate(llm_llm_input_tokens_total[5m])", "legendFormat": "Input tokens/s" },
        { "expr": "rate(llm_llm_output_tokens_total[5m])", "legendFormat": "Output tokens/s" }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Request Cost",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "rate(llm_llm_request_cost_total[5m])", "legendFormat": "Cost/s by {{provider}}" }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Active Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "targets": [
        { "expr": "llm_llm_active_requests", "legendFormat": "active" }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Traffic Distribution by Provider",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 24 },
      "targets": [
        { "expr": "llm_llm_requests_total", "legendFormat": "{{provider}}" }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    }
  ],
  "schemaVersion": 39,
  "tags": ["llm", "balancer", "v2"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "title": "LLM Balancer V2 — Advanced Monitoring",
  "uid": "llm-balancer-v2"
}
